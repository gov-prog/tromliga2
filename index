    function renderGrid(u=activeU||curU) {
        if(!u) return;
        const grid=document.getElementById('daysGrid'); grid.innerHTML='';
        const n=now(), start=new Date(START_DATE);
        const midnight=new Date(n.getFullYear(),n.getMonth(),n.getDate());
        const isPre=n.getTime()<END_OF_DAY1;
        const dayIdx=isPre?0:Math.min(Math.floor((midnight-start)/86400000),29);
        const dates=getDates();
        dates.forEach((date,i)=>{
            const ts=date.getTime();
            const done=(u.completedDates||[]).includes(ts);
            const failed=(u.failedDates||[]).includes(ts);
            let cls='locked';
            if(done) cls='completed';
            else if(failed) cls='failed';
            else if(i===dayIdx) cls='today';
            else if(i<dayIdx) cls='missed';
            const div=document.createElement('div');
            div.className=`day ${cls}`; div.id=`day-${ts}`;
            div.innerHTML=`<div class="day-num">יום ${i+1}</div><div class="day-date">${date.toLocaleDateString('he-IL',{day:'2-digit',month:'2-digit'})}</div>`;
            if(cls==='today'&&!done&&!failed)
                div.innerHTML+=`<div class="timer-chip" id="timer-${ts}">${getTimer()}</div>`;
