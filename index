    // ── STREAK ──
    function calcStreak(completedDates) {
        if(!completedDates?.length) return 0;
        const dates=getDates(), n=now();
        const midnight=new Date(n.getFullYear(),n.getMonth(),n.getDate()).getTime();
        const isPre=n.getTime()<END_OF_DAY1;
        const idx=isPre?0:Math.floor((midnight-START_DATE)/86400000)%30;
        let s=0;
        for(let i=idx;i>=0;i--) {
            if(completedDates.includes(dates[i]?.getTime())) s++;
            else break;
        }
        return s;
    }

    function getDates() {
        const d=[],s=new Date(START_DATE);
        for(let i=0;i<30;i++){const x=new Date(s);x.setDate(s.getDate()+i);d.push(x);}
        return d;
    }

    function getTimer() {
        const n=now();
        if(n.getTime()<END_OF_DAY1) {
            const diff=END_OF_DAY1-n.getTime();
            const h=Math.floor(diff/3600000),m=Math.floor((diff%3600000)/60000),s=Math.floor((diff%60000)/1000);
            return `${h}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
        }
        const end=new Date(); end.setHours(23,59,59,999);
        const d2=end-n;
        const h=Math.floor(d2/3600000),m=Math.floor((d2%3600000)/60000),s=Math.floor((d2%60000)/1000);
        return `${h}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
    }

    // ── MINI GRAPH ──
    function renderMiniGraph(u) {
        const mg = document.getElementById('miniGraph');
        if(!mg) return;
        mg.innerHTML = '';
        const dates = getDates();
        const n = now();
        const midnight = new Date(n.getFullYear(),n.getMonth(),n.getDate()).getTime();
        const isPre = n.getTime()<END_OF_DAY1;
        const dayIdx = isPre ? 0 : Math.min(Math.floor((midnight-START_DATE)/86400000), 29);
        dates.forEach((date, i) => {
            const ts = date.getTime();
            const done = (u.completedDates||[]).includes(ts);
            const failed = (u.failedDates||[]).includes(ts);
            const bar = document.createElement('div');
            bar.className = 'mg-bar';
            if(done) { bar.classList.add('done'); bar.style.height = '100%'; }
            else if(failed) { bar.classList.add('fail'); bar.style.height = '60%'; }
            else if(i===dayIdx) { bar.classList.add('today-bar'); bar.style.height = '50%'; }
            else if(i<dayIdx) { bar.style.height = '15%'; }
            else { bar.style.height = '8%'; }
            mg.appendChild(bar);
        });
    }

