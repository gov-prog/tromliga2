    async function updateLeaderData() {
        const snap=await getDocs(collection(db,COLLECTION));
        const users=[];
        snap.forEach(d=>{
            const data=d.data();
            const total=(data.completedDates?.length||0)+(data.bonusPoints||0)-(data.failedDates?.length||0);
            users.push({uid:d.id,total,...data});
        });
        users.sort((a,b)=>(b.total-a.total)||(a.lastPointTimestamp-b.lastPointTimestamp));
        allUsersCache = users;
        const displayU=activeU||curU;
        if(displayU){
            const idx=users.findIndex(u=>u.uid===displayU.uid);
            const rank = idx!==-1 ? idx+1 : null;
            document.getElementById('uRank').innerText=rank?'#'+rank:'--';
            document.getElementById('uPoints').innerText=users[idx]?.total||0;
            if(rank) updateWABtn(displayU, rank);
        }
        const top=users.slice(0,3);
        ['podium','adminPodium'].forEach(id=>{
            const p=document.getElementById(id); if(!p) return; p.innerHTML='';
            if(top[1]) p.innerHTML+=podHTML(top[1],2,'🥈');
            if(top[0]) p.innerHTML+=podHTML(top[0],1,'🥇');
            if(top[2]) p.innerHTML+=podHTML(top[2],3,'🥉');
        });
    }

    function getInitials(name) {
        const parts = name.trim().split(' ');
        if(parts.length >= 2) return parts[0][0] + parts[1][0];
        return name[0] || '?';
    }

    function podHTML(u,rank,icon) {
        const streak=calcStreak(u.completedDates||[]);
        const initials = getInitials(u.fullName);
        return `<div class="podium-item">
            <div class="pod-avatar">${initials}</div>
            <div class="pod-name">${u.fullName}${streak>=3?' 🔥':''}</div>
            <div class="pod-box pod-${rank}">
                <span style="font-size:20px">${icon}</span>
                <span style="font-size:11px;font-weight:800;margin-top:2px">${u.total} נק'</span>
            </div>
        </div>`;
    }

    window.hLB = async () => {
        showSection('leaderboard'); await updateLeaderData();
        renderPlayerList(allUsersCache);
        // load saved start date
        try {
            const cfg = await getDoc(doc(db,"configs","trom_liga_start"));
            if(cfg.exists()) {
                const d = new Date(cfg.data().startDate);
                const iso = d.toISOString().split('T')[0];
                document.getElementById('adminStartDate').value = iso;
            }
        } catch(e){}
    };

    function renderPlayerList(users) {
        const list=document.getElementById('uList'); list.innerHTML='';
        const medals=['🥇','🥈','🥉'];
        users.forEach((u,i)=>{
            const streak=calcStreak(u.completedDates||[]);
            const completed=(u.completedDates||[]).length;
            const failed=(u.failedDates||[]).length;
            const el=document.createElement('div');
            el.className='player-row';
            el.innerHTML=`
                <div style="display:flex;align-items:center;gap:12px">
                    <div class="player-rank">${medals[i]||'#'+(i+1)}</div>
                    <div>
                        <div class="player-name">${u.fullName}</div>
                        <div class="player-meta">
                            ${u.total} נקודות &nbsp;·&nbsp; ✅${completed} &nbsp;·&nbsp; ❌${failed}
                            ${streak>=3?' &nbsp;·&nbsp; 🔥'+streak+'ברצף':''}
                        </div>
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:6px">
                    <button class="small-btn" onclick="window.delPlayer('${u.id||u.uid}')">מחק</button>
                    <div class="admin-menu-btn" onclick="(function(el){el.style.display=el.style.display==='block'?'none':'block'})(document.getElementById('m-${u.id||u.uid}'));event.stopPropagation()">⋮
                        <div class="dropdown" id="m-${u.id||u.uid}">
                            <div class="dropdown-item" onclick="window.viewPlayer('${u.id||u.uid}')">📅 לוח שחקן — וי/איקס</div>
                            <div class="bonus-row">
                                <span style="font-size:13px;font-weight:700;color:var(--c-muted)">בונוס</span>
                                <div style="display:flex;gap:6px">
                                    <button class="bonus-btn" style="background:var(--c-green)" onclick="window.adminBonus('${u.id||u.uid}',1)">+</button>
                                    <button class="bonus-btn" style="background:var(--c-red)"   onclick="window.adminBonus('${u.id||u.uid}',-1)">−</button>
                                </div>
                            </div>
                            <div class="dropdown-creds">👤 ${u.fullName}<br>🔑 ${u.password||'—'}<br>✅ ${completed} ❌ ${failed}</div>
                        </div>
                    </div>
                </div>`;
            list.appendChild(el);
        });
    }

    window.filterPlayers = (q) => {
        if(!q) return renderPlayerList(allUsersCache);
        const filtered = allUsersCache.filter(u => u.fullName.includes(q));
        renderPlayerList(filtered);
    };

    // ── EXPORT CSV ──
    window.exportCSV = () => {
        if(!allUsersCache.length) return alert("אין נתונים לייצוא.");
        const headers = ['שם','נקודות','ימים שהושלמו','ימים שנכשלו','נק\' בונוס','ברצף'];
        const rows = allUsersCache.map((u,i) => {
            const completed = (u.completedDates||[]).length;
            const failed = (u.failedDates||[]).length;
            const streak = calcStreak(u.completedDates||[]);
            return [u.fullName, u.total, completed, failed, u.bonusPoints||0, streak];
        });
        const csv = [headers, ...rows].map(r => r.map(c => `"${c}"`).join(',')).join('\n');
        const blob = new Blob(["\uFEFF"+csv], {type:'text/csv;charset=utf-8;'});
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = `trom-liga-${new Date().toLocaleDateString('he-IL')}.csv`;
        a.click();
    };

    window.viewPlayer = async (uid) => {
        const s=await getDoc(doc(db,COLLECTION,uid));
        const data=s.data(); data.uid=uid; activeU=data;
        document.getElementById('uWelcomeMsg').innerText="ניהול: "+data.fullName+" 📋";
        renderGrid(activeU); updateStatBadges(activeU);
        renderMiniGraph(activeU);
        renderAchievements((activeU.completedDates||[]).length, calcStreak(activeU.completedDates||[]));
        showSection('dashboard');
    };

    function n2e(n) {
        let c=n.trim().toLowerCase(), h="";
        for(let i=0;i<c.length;i++) h+=c.charCodeAt(i).toString(16);
        return "u_"+h+"@tromlga.com";
    }

    // close dropdowns on tap
    document.addEventListener('click', ()=>{
        document.querySelectorAll('.dropdown').forEach(d=>d.style.display='none');
    });
</script>
</body>
</html>
