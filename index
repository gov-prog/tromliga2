<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>אתגר הכדורסל — טרום ליגה</title>
    <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <style>
    :root {
        --c-bg:      #060608;
        --c-s1:      #0f0f12;
        --c-s2:      #18181d;
        --c-s3:      #222228;
        --c-border:  rgba(255,255,255,0.05);
        --c-border2: rgba(255,255,255,0.10);
        --c-text:    #f0f0f0;
        --c-muted:   #555;
        --c-dim:     #383840;
        --c-orange:  #FF5C00;
        --c-amber:   #FF9500;
        --c-gold:    #FFD060;
        --c-red:     #FF3A3A;
        --c-green:   #00D26A;
        --grad-fire: linear-gradient(135deg, #FF5C00, #FF9500);
        --grad-gold: linear-gradient(135deg, #FFD060, #FF9500);
        --grad-dark: linear-gradient(160deg, #0f0f12 0%, #060608 100%);
        --shadow-orange: 0 0 40px rgba(255,92,0,0.2);
        --shadow-card: 0 8px 40px rgba(0,0,0,0.6);
        --r: 20px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
        font-family: 'Heebo', sans-serif;
        background: var(--c-bg);
        color: var(--c-text);
        min-height: 100vh;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
    }

    /* ── BACKGROUND ── */
    .bg-fx {
        position: fixed; inset: 0; z-index: 0; pointer-events: none;
        overflow: hidden;
    }
    .bg-orb {
        position: absolute; border-radius: 50%;
        filter: blur(80px); opacity: 0.12;
        animation: orbDrift 18s ease-in-out infinite alternate;
    }
    .bg-orb-1 { width: 500px; height: 500px; background: #FF5C00; top: -200px; right: -100px; animation-delay: 0s; }
    .bg-orb-2 { width: 350px; height: 350px; background: #FF9500; bottom: 100px; left: -80px; animation-delay: -6s; }
    .bg-orb-3 { width: 250px; height: 250px; background: #FFD060; top: 40%; right: 10%; animation-delay: -12s; opacity: 0.07; }
    @keyframes orbDrift {
        from { transform: translate(0,0) scale(1); }
        to   { transform: translate(30px,40px) scale(1.08); }
    }
    .bg-grid {
        position: absolute; inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,0.012) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.012) 1px, transparent 1px);
        background-size: 48px 48px;
    }
    .bg-vignette {
        position: absolute; inset: 0;
        background: radial-gradient(ellipse 80% 80% at 50% 50%, transparent 40%, rgba(6,6,8,0.8) 100%);
    }

    /* ── WRAP ── */
    .wrap {
        position: relative; z-index: 1;
        max-width: 470px; margin: 0 auto;
        padding: 0 14px 60px;
    }

    /* ── SECTIONS ── */
    section { display: none; }
    section.active { display: block; animation: pageIn 0.35s cubic-bezier(0.23,1,0.32,1); }
    @keyframes pageIn {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── CARDS ── */
    .card {
        background: var(--c-s1);
        border: 1px solid var(--c-border);
        border-radius: var(--r);
        padding: 20px;
        margin-bottom: 12px;
        box-shadow: var(--shadow-card);
        position: relative; overflow: hidden;
    }
    .card::before {
        content: '';
        position: absolute; top: 0; left: 0; right: 0; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
    }

    /* ── BUTTONS ── */
    .btn {
        display: flex; align-items: center; justify-content: center; gap: 8px;
        width: 100%; padding: 16px 20px;
        border: none; border-radius: 14px;
        font-family: 'Heebo', sans-serif;
        font-size: 16px; font-weight: 800;
        cursor: pointer; transition: all 0.2s cubic-bezier(0.23,1,0.32,1);
        margin-top: 10px; text-decoration: none; letter-spacing: 0.3px;
    }
    .btn:active { transform: scale(0.96); }
    .btn-fire {
        background: var(--grad-fire); color: #fff;
        box-shadow: 0 6px 28px rgba(255,92,0,0.4), inset 0 1px 0 rgba(255,255,255,0.15);
    }
    .btn-fire:hover { box-shadow: 0 8px 36px rgba(255,92,0,0.55); transform: translateY(-1px); }
    .btn-outline { background: transparent; color: var(--c-orange); border: 1.5px solid rgba(255,92,0,0.35); }
    .btn-outline:hover { border-color: var(--c-orange); background: rgba(255,92,0,0.06); }
    .btn-ghost { background: transparent; color: var(--c-muted); font-size: 14px; font-weight: 700; text-decoration: underline; box-shadow: none; }
    .btn-surface { background: var(--c-s2); color: var(--c-text); border: 1px solid var(--c-border2); }
    .btn-surface:hover { border-color: rgba(255,92,0,0.3); }
    .btn-red { background: var(--c-red); color: #fff; box-shadow: 0 4px 16px rgba(255,58,58,0.3); }
    .btn-green { background: var(--c-green); color: #000; box-shadow: 0 4px 16px rgba(0,210,106,0.3); }

    /* ── INPUTS ── */
    .inp {
        width: 100%; padding: 14px 16px;
        background: var(--c-s2);
        border: 1.5px solid var(--c-border2);
        border-radius: 12px;
        color: var(--c-text);
        font-family: 'Heebo', sans-serif;
        font-size: 15px; text-align: right;
        outline: none; transition: all 0.2s;
        margin: 6px 0;
    }
    .inp:focus { border-color: var(--c-orange); box-shadow: 0 0 0 3px rgba(255,92,0,0.1); }
    .inp::placeholder { color: #2a2a30; }

    /* ════════════════════════════════
       WELCOME
    ════════════════════════════════ */
    .hero { text-align: center; padding: 50px 16px 28px; }

    /* countdown */
    .countdown-banner {
        background: linear-gradient(135deg, rgba(255,92,0,0.12), rgba(255,149,0,0.08));
        border: 1px solid rgba(255,92,0,0.25);
        border-radius: 16px; padding: 14px 18px;
        margin-bottom: 20px; text-align: center;
    }
    .cd-label { font-size: 10px; font-weight: 900; color: var(--c-orange); letter-spacing: 2.5px; text-transform: uppercase; margin-bottom: 8px; }
    .cd-units { display: flex; justify-content: center; gap: 10px; }
    .cd-unit { display: flex; flex-direction: column; align-items: center; }
    .cd-num {
        font-size: 28px; font-weight: 900; line-height: 1;
        background: var(--grad-fire);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .cd-lbl { font-size: 9px; color: var(--c-muted); font-weight: 700; margin-top: 2px; }
    .cd-sep { font-size: 22px; font-weight: 900; color: var(--c-orange); opacity: 0.4; align-self: flex-start; margin-top: 4px; }

    .logo-ring {
        display: inline-flex; align-items: center; justify-content: center;
        width: 130px; height: 130px; border-radius: 50%;
        background: conic-gradient(#FF5C00 0deg, #FFD060 90deg, #FF9500 200deg, #FF5C00 360deg);
        padding: 3px;
        animation: spin 10s linear infinite;
        margin-bottom: 20px;
        box-shadow: 0 0 50px rgba(255,92,0,0.25), 0 0 100px rgba(255,92,0,0.1);
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .logo-ring img {
        width: 122px; height: 122px; border-radius: 50%;
        object-fit: cover; border: 4px solid var(--c-bg);
    }
    /* fallback emoji */
    .logo-ring .logo-fallback {
        width: 122px; height: 122px; border-radius: 50%;
        background: var(--c-s1); border: 4px solid var(--c-bg);
        display: flex; align-items: center; justify-content: center;
        font-size: 56px;
    }

    .hero-eyebrow { font-size: 10px; font-weight: 900; color: var(--c-orange); letter-spacing: 3.5px; text-transform: uppercase; margin-bottom: 8px; }
    .hero-title {
        font-size: 42px; font-weight: 900; line-height: 1.05;
        background: var(--grad-fire);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text; margin-bottom: 6px;
    }
    .hero-sub { font-size: 14px; color: var(--c-muted); margin-bottom: 28px; line-height: 1.5; }

    /* features row */
    .feat-row { display: flex; gap: 8px; margin-bottom: 20px; }
    .feat-chip {
        flex: 1; background: var(--c-s1);
        border: 1px solid var(--c-border2);
        border-radius: 14px; padding: 12px 8px; text-align: center;
    }
    .feat-icon { font-size: 20px; margin-bottom: 4px; }
    .feat-txt { font-size: 10px; font-weight: 800; color: var(--c-muted); }

    /* ════════════════════════════════
       AUTH
    ════════════════════════════════ */
    .auth-wrap { padding-top: 44px; }
    .back-btn { display: inline-flex; align-items: center; gap: 6px; color: var(--c-muted); font-size: 13px; font-weight: 700; cursor: pointer; margin-bottom: 18px; }
    .auth-title { font-size: 28px; font-weight: 900; }
    .auth-sub { font-size: 14px; color: var(--c-muted); margin-top: 4px; margin-bottom: 24px; }

    /* ════════════════════════════════
       INSTRUCTIONS
    ════════════════════════════════ */
    .alert-box {
        background: rgba(255,92,0,0.05);
        border: 1px solid rgba(255,92,0,0.18);
        border-radius: 16px; padding: 18px;
        font-size: 14px; color: #ffaa70;
        line-height: 1.75; margin-bottom: 14px;
    }
    .alert-box strong { color: var(--c-amber); }
    .yt-btn {
        display: flex; align-items: center; justify-content: center; gap: 10px;
        background: #CC0000; color: #fff;
        padding: 15px; border-radius: 14px;
        text-decoration: none; font-weight: 800;
        font-size: 15px; margin: 10px 0;
        box-shadow: 0 4px 20px rgba(204,0,0,0.3);
        transition: 0.2s;
    }
    .yt-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 28px rgba(204,0,0,0.45); }

    /* ════════════════════════════════
       DASHBOARD
    ════════════════════════════════ */
    .dash-topbar {
        display: flex; justify-content: space-between; align-items: center;
        padding: 18px 0 14px;
    }
    .dash-name { font-size: 22px; font-weight: 900; }
    .dash-sub-txt { font-size: 12px; color: var(--c-muted); margin-top: 2px; }
    .exit-btn {
        background: var(--c-s2); border: 1px solid var(--c-border2);
        border-radius: 10px; color: var(--c-muted);
        font-family: 'Heebo', sans-serif; font-size: 12px; font-weight: 700;
        padding: 8px 14px; cursor: pointer; transition: 0.2s;
    }
    .exit-btn:hover { border-color: rgba(255,92,0,0.3); color: var(--c-orange); }

    /* ── STATS ── */
    .stats-row { display: flex; gap: 8px; margin-bottom: 12px; }
    .stat-chip {
        flex: 1; background: var(--c-s1);
        border: 1px solid var(--c-border2);
        border-radius: 18px; padding: 16px 10px 14px;
        text-align: center; position: relative; overflow: hidden;
        transition: transform 0.2s, border-color 0.2s;
    }
    .stat-chip:hover { transform: translateY(-2px); border-color: rgba(255,92,0,0.3); }
    .stat-chip::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
        background: var(--grad-fire); opacity: 0; transition: opacity 0.3s;
    }
    .stat-chip.lit::before { opacity: 1; }
    .stat-val {
        display: block; font-size: 28px; font-weight: 900; line-height: 1;
        background: var(--grad-fire);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .stat-chip.rank-chip .stat-val { background: var(--grad-gold); -webkit-background-clip: text; background-clip: text; }
    .stat-chip.streak-chip .stat-val { -webkit-text-fill-color: #FF3A3A; }
    .stat-lbl { font-size: 10px; color: var(--c-dim); font-weight: 700; margin-top: 5px; letter-spacing: 0.5px; text-transform: uppercase; }

    /* ── PROGRESS ── */
    .prog-wrap { margin-bottom: 12px; }
    .prog-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .prog-meta span { font-size: 12px; font-weight: 700; color: var(--c-muted); }
    .prog-meta strong { color: var(--c-amber); }
    .prog-track { height: 7px; background: var(--c-s3); border-radius: 99px; overflow: hidden; }
    .prog-bar {
        height: 100%; border-radius: 99px; background: var(--grad-fire);
        transition: width 1.4s cubic-bezier(0.23,1,0.32,1);
        position: relative; overflow: hidden;
    }
    .prog-bar::after {
        content: ''; position: absolute; inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent);
        animation: shim 2.2s infinite;
    }
    @keyframes shim { 0%{transform:translateX(-100%)} 100%{transform:translateX(200%)} }

    /* ── QUOTE ── */
    .quote-wrap {
        padding: 16px 18px 14px;
        background: var(--c-s1); border: 1px solid var(--c-border);
        border-radius: 18px; margin-bottom: 12px; position: relative; overflow: hidden;
    }
    .quote-wrap::before {
        content: '\201C'; position: absolute; top: -10px; right: 10px;
        font-size: 100px; font-weight: 900; line-height: 1;
        color: rgba(255,92,0,0.06); font-family: Georgia, serif;
    }
    .quote-line { font-size: 13px; color: #aaa; font-style: italic; line-height: 1.7; position: relative; }
    .quote-by { font-size: 11px; color: var(--c-orange); font-weight: 800; margin-top: 8px; }

    /* ── POTD ── */
    .potd {
        display: flex; align-items: center; gap: 14px;
        padding: 16px 18px;
        background: linear-gradient(135deg, rgba(255,208,96,0.07), rgba(255,92,0,0.04));
        border: 1px solid rgba(255,208,96,0.15);
        border-radius: 18px; margin-bottom: 12px; position: relative; overflow: hidden;
    }
    .potd-star { font-size: 28px; flex-shrink: 0; }
    .potd-badge { font-size: 9px; font-weight: 900; color: var(--c-gold); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 4px; }
    .potd-nm { font-size: 17px; font-weight: 900; }
    .potd-empty-txt { font-size: 13px; color: var(--c-muted); }

    /* ── SECTION LABEL ── */
    .sec-label { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
    .sec-label h3 { font-size: 12px; font-weight: 900; color: var(--c-muted); text-transform: uppercase; letter-spacing: 1.5px; }
    .sec-right { font-size: 12px; color: var(--c-orange); font-weight: 800; }

    /* ── PODIUM ── */
    .podium-wrap {
        display: flex; justify-content: center; align-items: flex-end;
        gap: 8px; height: 150px; padding: 0 4px;
    }
    .podium-item {
        display: flex; flex-direction: column; align-items: center; width: 32%;
        animation: podUp 0.55s cubic-bezier(0.23,1,0.32,1) backwards;
    }
    .podium-item:nth-child(1){animation-delay:.12s}
    .podium-item:nth-child(2){animation-delay:0s}
    .podium-item:nth-child(3){animation-delay:.24s}
    @keyframes podUp { from{transform:translateY(24px);opacity:0} to{transform:translateY(0);opacity:1} }
    .pod-avatar {
        width: 32px; height: 32px; border-radius: 50%;
        background: var(--c-s2); border: 2px solid var(--c-border2);
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; font-weight: 900; margin-bottom: 4px;
        color: var(--c-text);
    }
    .pod-name { font-size: 10px; font-weight: 800; color: var(--c-text); text-align: center; width: 100%; margin-bottom: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .pod-box {
        width: 100%; border-radius: 10px 10px 4px 4px;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 2px; font-weight: 800;
    }
    .pod-1 { height: 96px; background: linear-gradient(160deg, #FFD700, #FF9500); box-shadow: 0 4px 20px rgba(255,215,0,0.25); }
    .pod-2 { height: 70px; background: linear-gradient(160deg, #C0C0C0, #888); }
    .pod-3 { height: 54px; background: linear-gradient(160deg, #CD7F32, #7B4A1E); }

    /* ── DAYS GRID ── */
    .grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 7px; }
    .day {
        aspect-ratio: 1; background: var(--c-s2);
        border: 1px solid var(--c-border); border-radius: 13px;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        cursor: pointer; transition: all 0.22s cubic-bezier(0.23,1,0.32,1);
        position: relative; overflow: hidden;
    }
    .day .day-num { font-size: 10px; font-weight: 800; color: var(--c-dim); margin-bottom: 1px; }
    .day .day-date { font-size: 9px; font-weight: 700; color: var(--c-muted); }
    .day.locked { border-style: dashed; border-color: #1a1a22; cursor: not-allowed; }
    .day.locked .day-num, .day.locked .day-date { color: #222; }
    .day.missed { background: #0d0d10; border-color: #161618; cursor: default; }
    .day.missed .day-num, .day.missed .day-date { color: #2a2a30; }
    .day.completed {
        background: linear-gradient(135deg, #FF5C00, #FF9500);
        border-color: transparent;
        box-shadow: 0 3px 16px rgba(255,92,0,0.4);
    }
    .day.completed .day-num { color: rgba(255,255,255,0.55); }
    .day.completed .day-date { display: none; }
    .day.completed::after { content: '✔'; font-size: 20px; color: #fff; font-weight: 900; position: absolute; }
    .day.failed { background: linear-gradient(135deg, #6b0000, #c02020); border-color: transparent; }
    .day.failed .day-num { color: rgba(255,255,255,0.4); }
    .day.failed .day-date { display: none; }
    .day.failed::after { content: '✘'; font-size: 20px; color: #fff; font-weight: 900; position: absolute; }
    .day.today {
        background: var(--c-s1); border: 2px solid var(--c-orange);
        cursor: pointer;
        animation: todayGlow 2.5s ease-in-out infinite;
    }
    .day.today .day-num { color: var(--c-orange); }
    .day.today .day-date { color: var(--c-amber); }
    @keyframes todayGlow {
        0%,100% { box-shadow: 0 0 10px rgba(255,92,0,0.1); }
        50%      { box-shadow: 0 0 24px rgba(255,92,0,0.5); }
    }
    .timer-chip {
        position: absolute; bottom: 3px;
        font-size: 6px; font-weight: 900;
        background: var(--c-red); color: #fff;
        padding: 1px 5px; border-radius: 5px;
    }

    /* ════════════════════════════════
       ACHIEVEMENTS SHOWCASE (new!)
    ════════════════════════════════ */
    .ach-scroll {
        display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px;
        scrollbar-width: none;
    }
    .ach-scroll::-webkit-scrollbar { display: none; }
    .ach-badge {
        flex-shrink: 0;
        width: 72px; height: 72px; border-radius: 18px;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 4px; border: 1.5px solid;
        transition: transform 0.2s;
        cursor: default;
    }
    .ach-badge:hover { transform: scale(1.06); }
    .ach-badge.earned {
        background: linear-gradient(135deg, rgba(255,92,0,0.15), rgba(255,149,0,0.08));
        border-color: rgba(255,92,0,0.35);
    }
    .ach-badge.locked-ach {
        background: rgba(255,255,255,0.02);
        border-color: rgba(255,255,255,0.05);
        opacity: 0.4;
        filter: grayscale(1);
    }
    .ach-icon { font-size: 26px; }
    .ach-lbl { font-size: 8px; font-weight: 800; color: var(--c-muted); text-align: center; letter-spacing: 0.3px; }

    /* ════════════════════════════════
       FIRE STREAK BANNER (new!)
    ════════════════════════════════ */
    .streak-banner {
        background: linear-gradient(135deg, rgba(255,58,58,0.12), rgba(255,92,0,0.08));
        border: 1px solid rgba(255,58,58,0.25);
        border-radius: 16px; padding: 14px 18px;
        display: flex; align-items: center; gap: 14px;
        margin-bottom: 12px;
        animation: streakPulse 3s ease-in-out infinite;
    }
    @keyframes streakPulse {
        0%,100% { border-color: rgba(255,58,58,0.2); }
        50%      { border-color: rgba(255,92,0,0.5); }
    }
    .streak-fire { font-size: 36px; animation: fireWiggle 0.8s ease-in-out infinite alternate; }
    @keyframes fireWiggle {
        from { transform: rotate(-5deg) scale(1); }
        to   { transform: rotate(5deg) scale(1.1); }
    }
    .streak-text .st-num {
        font-size: 24px; font-weight: 900;
        background: linear-gradient(135deg, #FF3A3A, #FF9500);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .streak-text .st-lbl { font-size: 12px; color: var(--c-muted); font-weight: 700; }

    /* ════════════════════════════════
       MINI GRAPH (new!)
    ════════════════════════════════ */
    .mini-graph {
        display: flex; align-items: flex-end; gap: 3px;
        height: 40px; margin-top: 10px;
    }
    .mg-bar {
        flex: 1; border-radius: 3px 3px 0 0;
        background: var(--c-s3); min-height: 3px;
        transition: height 0.8s cubic-bezier(0.23,1,0.32,1);
    }
    .mg-bar.done { background: var(--grad-fire); }
